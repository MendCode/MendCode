# Dependencies / build output
node_modules/
dist/
build/
coverage/

# Local developer launcher shims. Package bins under src/**/bin stay tracked.
/bin/

# Secrets and local env
.env
.env.*
!.env.example

# MendCode generated/runtime state. The release repo must not carry local
# project state; users get a fresh .mendcode from `mend init`.
.mendcode/

# MendCode package artifacts. Some package snapshots are still tracked for now,
# but new local files under those app/docs surfaces must stay off git until
# they are split or deliberately re-owned.
